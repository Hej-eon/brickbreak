<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neon Brick Breaker</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background: #050816;
    color: #00ffff;
    font-family: Arial, sans-serif;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

/* Game Container */
.game-wrapper {
    position: relative;
}

canvas {
    background: linear-gradient(180deg, #0a0f25, #020308);
    border: 2px solid #00ffff;
    box-shadow:
        0 0 10px #00ffff,
        0 0 20px #00ffff,
        inset 0 0 20px rgba(0,255,255,0.2);
}

/* Scoreboard */
.scoreboard {
    position: absolute;
    top: -40px;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    color: #00ffff;
    font-size: 20px;
    text-shadow: 0 0 8px #00ffff;
}

/* Overlay */
.overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.75);
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    text-align: center;
}

.overlay h1 {
    font-size: 56px;
    margin-bottom: 20px;
    text-shadow: 0 0 20px #00ffff;
}

.overlay p {
    font-size: 20px;
    color: white;
}
</style>

</head>
<body>

<div class="game-wrapper">
    <div class="scoreboard">
        <div>Score: <span id="score">0</span></div>
        <div>Bricks: <span id="remaining">30</span></div>
    </div>

    <canvas id="gameCanvas" width="800" height="600"></canvas>

    <div class="overlay" id="overlay">
        <h1 id="message"></h1>
        <p>Refresh page to play again</p>
    </div>
</div>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

const scoreEl = document.getElementById("score");
const remainingEl = document.getElementById("remaining");
const overlay = document.getElementById("overlay");
const message = document.getElementById("message");

// Score
let score = 0;

// Paddle
const paddle = {
    width: 120,
    height: 15,
    x: canvas.width / 2 - 60,
    y: canvas.height - 35,
    speed: 8
};

// Ball
const ball = {
    x: canvas.width / 2,
    y: canvas.height - 60,
    radius: 8,
    dx: 4,
    dy: -4
};

// Controls
let leftPressed = false;
let rightPressed = false;

document.addEventListener("keydown", e => {
    if (e.key === "ArrowLeft") leftPressed = true;
    if (e.key === "ArrowRight") rightPressed = true;
});

document.addEventListener("keyup", e => {
    if (e.key === "ArrowLeft") leftPressed = false;
    if (e.key === "ArrowRight") rightPressed = false;
});

// Bricks
const brickRows = 5;
const brickCols = 6;
const brickWidth = 110;
const brickHeight = 25;
const brickPadding = 12;
const offsetTop = 60;
const offsetLeft = 35;

const bricks = [];

for (let c = 0; c < brickCols; c++) {
    bricks[c] = [];
    for (let r = 0; r < brickRows; r++) {
        bricks[c][r] = { status: 1 };
    }
}

function drawPaddle() {
    ctx.fillStyle = "#00ffff";
    ctx.shadowColor = "#00ffff";
    ctx.shadowBlur = 15;

    ctx.fillRect(
        paddle.x,
        paddle.y,
        paddle.width,
        paddle.height
    );

    ctx.shadowBlur = 0;
}

function drawBall() {
    ctx.beginPath();
    ctx.arc(ball.x, ball.y, ball.radius, 0, Math.PI * 2);

    ctx.fillStyle = "#ff00ff";
    ctx.shadowColor = "#ff00ff";
    ctx.shadowBlur = 20;

    ctx.fill();
    ctx.closePath();

    ctx.shadowBlur = 0;
}

function drawBricks() {
    let remaining = 0;

    for (let c = 0; c < brickCols; c++) {
        for (let r = 0; r < brickRows; r++) {

            if (bricks[c][r].status === 1) {

                remaining++;

                const brickX =
                    c * (brickWidth + brickPadding) + offsetLeft;

                const brickY =
                    r * (brickHeight + brickPadding) + offsetTop;

                bricks[c][r].x = brickX;
                bricks[c][r].y = brickY;

                ctx.fillStyle = "#00ff88";
                ctx.shadowColor = "#00ff88";
                ctx.shadowBlur = 15;

                ctx.fillRect(
                    brickX,
                    brickY,
                    brickWidth,
                    brickHeight
                );

                ctx.shadowBlur = 0;
            }
        }
    }

    remainingEl.textContent = remaining;
}

function collisionDetection() {

    for (let c = 0; c < brickCols; c++) {
        for (let r = 0; r < brickRows; r++) {

            const b = bricks[c][r];

            if (b.status === 1) {

                if (
                    ball.x > b.x &&
                    ball.x < b.x + brickWidth &&
                    ball.y > b.y &&
                    ball.y < b.y + brickHeight
                ) {
                    ball.dy = -ball.dy;
                    b.status = 0;

                    score += 10;
                    scoreEl.textContent = score;

                    if (score === brickRows * brickCols * 10) {
                        endGame("YOU WIN!");
                    }
                }
            }
        }
    }
}

function movePaddle() {

    if (leftPressed && paddle.x > 0) {
        paddle.x -= paddle.speed;
    }

    if (
        rightPressed &&
        paddle.x < canvas.width - paddle.width
    ) {
        paddle.x += paddle.speed;
    }
}

function moveBall() {

    ball.x += ball.dx;
    ball.y += ball.dy;

    // Side walls
    if (
        ball.x + ball.radius > canvas.width ||
        ball.x - ball.radius < 0
    ) {
        ball.dx = -ball.dx;
    }

    // Top wall
    if (ball.y - ball.radius < 0) {
        ball.dy = -ball.dy;
    }

    // Paddle collision
    if (
        ball.y + ball.radius > paddle.y &&
        ball.x > paddle.x &&
        ball.x < paddle.x + paddle.width
    ) {
        ball.dy = -Math.abs(ball.dy);
    }

    // Bottom = Game Over
    if (ball.y > canvas.height) {
        endGame("GAME OVER");
    }
}

let gameRunning = true;

function endGame(text) {
    gameRunning = false;
    message.textContent = text;
